# Root-level .gitignore for IJSAgroAllied project
# This file ignores items at the project root level
# Frontend and backend have their own specific .gitignore files

# Dependencies
node_modules/

# Leftover directories from migration (to be removed manually)
my-app/

# Build outputs
dist/
build/

# Environment files
.env
.env.local
.env.*.local

# IDE and editor files
.vscode/
.idea/
*.swp
*.swo
*~

# OS files
.DS_Store
Thumbs.db
desktop.ini

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# Testing
coverage/
.nyc_output/

# Temporary files
*.tmp
*.temp
.cache/

# Lock files (keep package-lock.json but ignore others)
yarn.lock
pnpm-lock.yaml

# Build info
.next/
out/

# Misc
*.tsbuildinfo
